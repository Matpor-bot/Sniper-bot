# ==========================================
# Portfolio ORB Multi v12.1
# XAUUSD v10.3 + NAS100 v11 + GER40/DAX v12
# Subir UM ÚNICO programa no Railway
# ==========================================

BOT_TELEGRAM=true
TELEGRAM_BOT_TOKEN=COLE_SEU_TOKEN_AQUI
TELEGRAM_CHAT_ID=COLE_SEU_CHAT_ID_AQUI
TELEGRAM_PARSE_MODE=HTML
BOT_TIMEZONE=America/Sao_Paulo
ACCOUNT_BALANCE=500

STRATEGY_MODE=PORTFOLIO_ORB_MULTI
STRATEGY_NAME=Portfolio ORB Multi - XAUUSD v10.3 + NAS100 v11 + GER40 v12
RECOMMENDED_TIMEFRAME=M5
MAX_STORED_CANDLES=900

# Gestão de carteira
MAX_TOTAL_OPEN_SIGNALS=3
MAX_OPEN_SIGNALS_PER_MARKET=1
ALLOW_MULTIPLE_OPEN_SIGNALS=false
TIMEOUT_CLOSE_AS_RESULT=true
SAME_CANDLE_POLICY=conservative
WIN_LOSS_ALERTS=true
BLOCK_WEEKEND=true
SEND_HOLD_SIGNALS=false

# Notícias: opcional. Se preencher janelas UTC, todos os robôs respeitam.
NEWS_BLACKOUT_ENABLED=false
NEWS_BLACKOUT_WINDOWS_UTC=
BLOCK_HIGH_IMPACT_FLAG=true

# Spread real quando o webhook enviar bid/ask.
ORB_SPREAD_GUARD_ENABLED=true
SPREAD_UNKNOWN_POLICY=ignore

# ==========================================
# Perfil 1 — Gold v10.3 validado
# ==========================================
XAU_RISK_PER_TRADE_PCT=3.0
