XAU_ORB_STOP_RANGE_MULT=0.75
XAU_ORB_TAKE_R=1.5
XAU_ORB_MIN_RANGE_ATR=0.35
XAU_ORB_MAX_RANGE_ATR=3.5
XAU_ORB_MAX_RANGE_PCT=0.025
XAU_ORB_MIN_STOP_POINTS=1.2
XAU_ORB_MAX_STOP_POINTS=10.0
XAU_ROUND_TURN_COST_POINTS=0.50
XAU_BLOCKED_WEEKDAYS=2
XAU_MAX_REAL_SPREAD_POINTS=0.50
XAU_MAX_BARS_IN_SIGNAL=48
XAU_PIP_VALUE_PER_LOT_USD=10

