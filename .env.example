# Railway / API
BOT_SYMBOL=BTCUSD
BOT_TIMEFRAME=1
BOT_BARS=300
MAX_STORED_CANDLES=300

# Telegram
BOT_TELEGRAM=true
BOT_STARTUP_ALERT=true
TELEGRAM_BOT_TOKEN=123456:ABCDEF
TELEGRAM_CHAT_ID=123456789
TELEGRAM_PARSE_MODE=HTML

# Horario
BOT_TIMEZONE=America/Sao_Paulo
BOT_TIME_FORMAT=%d/%m/%Y %H:%M:%S

# Confirmacao WIN/LOSS
WIN_LOSS_ALERTS=true
SAME_CANDLE_POLICY=conservative
MAX_OPEN_SIGNALS=50
ALLOW_MULTIPLE_OPEN_SIGNALS=false

# Estrategia Pro Scalper v6
STRATEGY_NAME=Pro Scalper v6 - EMA/VWAP/RSI/MACD/ADX/ATR
EMA_FAST=9
EMA_SLOW=21
EMA_TREND=50
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
ATR_PERIOD=14
ADX_PERIOD=14
BB_PERIOD=20
BB_STD=2.0
VWAP_PERIOD=50
VOLUME_PERIOD=20
BREAKOUT_LOOKBACK=5
SCORE_THRESHOLD=7
SCORE_DIFF_MIN=2
MIN_ADX=18
MIN_ATR_PCT=0.00025
MAX_ATR_PCT=0.025
MIN_VOLUME_MULT=1.05
MIN_BODY_RATIO=0.35
ATR_STOP_MULT=1.2
ATR_TAKE_MULT=1.6

# Logs
LOG_LEVEL=INFO
