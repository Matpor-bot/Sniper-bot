BOT_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BOT_TIMEZONE=America/Sao_Paulo
ACCOUNT_BALANCE=1000

# Configuração usada no backtest v8.2. Para real, considere começar com 0.5 a 1.0.
RISK_PER_TRADE_PCT=2.0

SYMBOL_ALLOWLIST=EURUSD,GBPUSD,XAUUSD
SESSION_FILTER_ENABLED=true
SESSION_WINDOWS_UTC=06:00-18:00
RECOMMENDED_TIMEFRAME=M5

# Filtro v8.2: horários/dias com melhor edge no treino Jan-Ago/2025 e validação Set-Dez/2025.
# Dias: 0=segunda, 1=terça, 2=quarta, 3=quinta, 4=sexta.
EDGE_SCHEDULE_FILTER_ENABLED=true
EDGE_ALLOWED_HOURS_UTC=EURUSD:6,7,10,12,13,15|GBPUSD:9,10,11,12|XAUUSD:8,10,12,13,16
EDGE_ALLOWED_WEEKDAYS_UTC=EURUSD:0,1,3|GBPUSD:3,4|XAUUSD:0,1,2,4
MAX_TOTAL_OPEN_SIGNALS=2
MAX_OPEN_SIGNALS_PER_MARKET=1

EMA_FAST=9
EMA_SLOW=21
EMA_TREND=75
MIN_ADX=10
DI_RATIO_MIN=1.0
RSI_BUY_LOW=50
RSI_BUY_HIGH=80
RSI_SELL_LOW=38
RSI_SELL_HIGH=55
MIN_BODY_RATIO=0.35
PULLBACK_ATR_MULT=0.35
ALLOW_BREAKOUT_SETUP=true
ALLOW_LIQUIDITY_SWEEP_SETUP=true
MAX_DIST_FROM_EMA_ATR=1.25
MIN_ATR_PCT=0.00004
MAX_ATR_PCT=0.006
MAX_CHOP=65
MAX_CANDLE_ATR_MULT=2.4
MIN_EMA_SEPARATION_PCT=0.00002
ATR_STOP_MULT=0.85
ATR_TAKE_MULT=0.765
COOLDOWN_BARS=0
MAX_BARS_IN_SIGNAL=5
MTF_FACTOR=3
SPREAD_UNKNOWN_POLICY=ignore
SAME_CANDLE_POLICY=conservative

SCORE_THRESHOLD=9
SCORE_DIFF_MIN=2
EMA_SLOPE_BARS=5
MIN_STOP_XAU_PIPS=18
MAX_STOP_XAU_PIPS=120
