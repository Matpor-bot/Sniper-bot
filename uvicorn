#!/usr/bin/env python3
"""Compatibility wrapper for hosts that run: uvicorn ... --port '$PORT'.
It replaces the literal string $PORT with the real PORT environment value.
"""
import os
import sys
from uvicorn.main import main

args = []
for arg in sys.argv[1:]:
    if arg == "$PORT":
        args.append(os.environ.get("PORT", "8000"))
    else:
        args.append(arg)

# If a bad --port value still arrives, replace it with PORT or 8000.
for i, arg in enumerate(args[:-1]):
    if arg == "--port":
        try:
            int(args[i + 1])
        except ValueError:
            args[i + 1] = os.environ.get("PORT", "8000")

sys.argv = ["uvicorn"] + args
main()
